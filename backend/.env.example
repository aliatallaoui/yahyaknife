# ─── Required ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/saas-dashboard
JWT_SECRET=generate-a-64-char-hex-string-with-openssl-rand-hex-32
CORS_ORIGIN=http://localhost:5173

# ─── Optional ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# ─── External Services (optional) ────────────────────────────────────────────
GEMINI_API_KEY=
SENTRY_DSN=

# ─── Fallback DB URIs (legacy, prefer MONGO_URI) ────────────────────────────
# PROD_MONGO_URI=
# DEV_MONGO_URI=
# ATLAS_MONGO_URI=
