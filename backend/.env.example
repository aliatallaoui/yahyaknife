# ─── Required ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/saas-dashboard
JWT_SECRET=generate-a-64-char-hex-string-with-openssl-rand-hex-32
CORS_ORIGIN=http://localhost:5173

# ─── Optional ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# ─── External Services (optional) ────────────────────────────────────────────
GEMINI_API_KEY=
SENTRY_DSN=

# ─── Fallback DB URIs (legacy, prefer MONGO_URI) ────────────────────────────
# PROD_MONGO_URI=
# DEV_MONGO_URI=
# ATLAS_MONGO_URI=

# Credential encryption key (32 bytes or 64 hex chars) — for encrypting store API keys
# CREDENTIAL_ENCRYPTION_KEY=

# App config for WooCommerce OAuth
# APP_NAME=Octomatic
# APP_BASE_URL=https://app.octomatic.shop
# API_BASE_URL=https://api.octomatic.shop
